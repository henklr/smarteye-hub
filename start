#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-$HOME/sei-raspi}"
IMAGE_NAME="${IMAGE_NAME:-sei-raspi}"
CONTAINER_NAME="${CONTAINER_NAME:-sei-raspi}"
PORT="${PORT:-8000}"
ALARM_PORT="${ALARM_PORT:-15000}"

log()  { echo -e "\033[1;32m[start]\033[0m $*"; }
warn() { echo -e "\033[1;33m[warn]\033[0m  $*"; }

# Use sudo docker if user isn't in docker group
DOCKER="docker"
if ! groups "$USER" | grep -q "\bdocker\b"; then
  DOCKER="sudo docker"
  warn "User '$USER' is not in the docker group — using sudo for docker."
fi

log "Stopping/removing existing container (if any): $CONTAINER_NAME..."
$DOCKER stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
$DOCKER rm "$CONTAINER_NAME" >/dev/null 2>&1 || true

log "Starting container on ports $PORT (web) and $ALARM_PORT (alarms)..."
$DOCKER run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  -p "$PORT:$PORT" \
  -p "$ALARM_PORT:$ALARM_PORT" \
  -e PYTHONUNBUFFERED=1 \
  "$IMAGE_NAME"

log "Published ports:"
$DOCKER port "$CONTAINER_NAME"

log "Done."
log "Logs: $DOCKER logs -f $CONTAINER_NAME"