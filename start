#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-$HOME/onvif-demo}"
IMAGE_NAME="${IMAGE_NAME:-onvif-demo}"
CONTAINER_NAME="${CONTAINER_NAME:-onvif-demo}"
PORT="${PORT:-8000}"

log()  { echo -e "\033[1;32m[start]\033[0m $*"; }
warn() { echo -e "\033[1;33m[warn]\033[0m  $*"; }

DOCKER="${DOCKER:-docker}"
if ! $DOCKER info >/dev/null 2>&1; then
  DOCKER="sudo docker"
  warn "Docker daemon not accessible — using sudo for docker."
fi

log "Stopping/removing existing container (if any): $CONTAINER_NAME..."
$DOCKER stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
$DOCKER rm "$CONTAINER_NAME" >/dev/null 2>&1 || true

log "Creating data directory..."
mkdir -p "$APP_DIR/data"

log "Starting container on port $PORT (web)..."
$DOCKER run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  -p "$PORT:$PORT" \
  -v "$APP_DIR/data:/app/data" \
  -e PORT="$PORT" \
  -e PYTHONUNBUFFERED=1 \
  "$IMAGE_NAME"

log "Published ports:"
$DOCKER port "$CONTAINER_NAME"

log "Done."
log "Logs: $DOCKER logs -f $CONTAINER_NAME"
