#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DIR:-$HOME/sei-raspi}"
IMAGE_NAME="${IMAGE_NAME:-sei-raspi}"
CONTAINER_NAME="${CONTAINER_NAME:-sei-raspi}"
PORT="${PORT:-8000}"

log()  { echo -e "\033[1;32m[start]\033[0m $*"; }
warn() { echo -e "\033[1;33m[warn]\033[0m  $*"; }

# Use sudo docker if daemon socket is not accessible
DOCKER="${DOCKER:-docker}"
if ! $DOCKER info >/dev/null 2>&1; then
  DOCKER="sudo docker"
  warn "Docker daemon not accessible — using sudo for docker."
fi

log "Stopping/removing existing container (if any): $CONTAINER_NAME..."
$DOCKER stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
$DOCKER rm "$CONTAINER_NAME" >/dev/null 2>&1 || true

log "Creating data directories..."
mkdir -p "$HOME/sei-raspi/data" "$HOME/sei-raspi/secrets"

if [[ ! -f "$HOME/sei-raspi/secrets/openai.env" ]]; then
  warn "Missing secrets file: $HOME/sei-raspi/secrets/openai.env"
  warn "Continuing anyway (ONVIF features do not require it)."
fi

log "Starting container (host network). App will listen on host port: $PORT"
$DOCKER run -d \
  --name "$CONTAINER_NAME" \
  --restart unless-stopped \
  --network host \
  -v "$HOME/sei-raspi/data:/app/data" \
  --env-file "$HOME/sei-raspi/secrets/openai.env" \
  -e PORT="$PORT" \
  -e PYTHONUNBUFFERED=1 \
  "$IMAGE_NAME"

HOST_IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
HOST_IP="${HOST_IP:-127.0.0.1}"

log "Done."
log "Open: http://${HOST_IP}:${PORT}/"
log "Logs: $DOCKER logs -f $CONTAINER_NAME"
