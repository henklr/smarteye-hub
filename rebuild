#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$HOME/sei-raspi"
IMAGE_NAME="sei-raspi"

log()  { echo -e "\033[1;32m[rebuild]\033[0m $*"; }
warn() { echo -e "\033[1;33m[warn]\033[0m  $*"; }

# Use sudo docker if daemon socket is not accessible
DOCKER="docker"
if ! docker info >/dev/null 2>&1; then
  DOCKER="sudo docker"
  warn "Docker daemon not accessible — using sudo for docker."
fi

log "Changing to $APP_DIR..."
cd "$APP_DIR"

log "Building Docker image: $IMAGE_NAME..."
$DOCKER build --pull -t "$IMAGE_NAME" .

log "Starting container..."
./start
